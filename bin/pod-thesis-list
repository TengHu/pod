#!/usr/bin/env bash
# pod-thesis-list — list existing thesis slugs, sorted by most-recently-touched.
#
# Usage:
#   pod-thesis-list           # prints "<slug>  <YYYY-MM-DD>" one per line, newest first
#   pod-thesis-list --json    # one JSON object per line: {"slug":"...","last_touched":"..."}
#
# "Touched" = mtime of the newest .md or .jsonl file inside the thesis directory.
# Empty output (exit 0) if no theses exist yet.
set -euo pipefail

eval "$("$(dirname "$0")/pod-paths")"

[ -d "$POD_THESES" ] || exit 0

# Portable mtime extraction (BSD/macOS uses -f, GNU uses -c).
mtime_of() {
  stat -f "%m" "$1" 2>/dev/null || stat -c "%Y" "$1" 2>/dev/null || echo 0
}

FORMAT="${1:-text}"

for dir in "$POD_THESES"/*/; do
  [ -d "$dir" ] || continue
  slug=$(basename "$dir")
  newest=$(find "$dir" -type f \( -name "*.md" -o -name "*.jsonl" \) 2>/dev/null \
    | while read -r f; do mtime_of "$f"; done \
    | sort -rn | head -1)
  newest="${newest:-0}"
  date_str=$(date -r "$newest" +%Y-%m-%d 2>/dev/null || echo unknown)
  echo "$newest|$slug|$date_str"
done \
| sort -rn -t'|' -k1,1 \
| while IFS='|' read -r mtime slug date_str; do
    if [ "$FORMAT" = "--json" ]; then
      printf '{"slug":"%s","last_touched":"%s"}\n' "$slug" "$date_str"
    else
      printf '%-40s  %s\n' "$slug" "$date_str"
    fi
  done
